// packages/db/prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}


// 테스트용 임시 테이블
model HealthCheck {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())
}
